{{!-- Partial cho một mục nhiệm vụ trong danh  --}}
<li class="task-item {{#if completed}}completed{{/if}}">
     <div class="task-item-content">
         <h3>
            <a href="/tasks/{{id}}">{{name}}</a>
        </h3>
        <p>{{description}}</p>
        <small>Trạng thái: {{isCompleted completed}}</small>
    </div>
    <div class="task-actions">
        <a href="/tasks/edit/{{id}}" class="edit-btn">Sửa</a>
        <form action="/tasks/toggle/{{id}}" method="POST" style="display:inline;">
            <button type="submit" class="toggle-btn">{{#if completed}}Chưa hoàn thành{{else}}Hoàn thành{{/if}}</button>
        </form>
        <form action="/tasks/delete/{{id}}" method="POST" style="display:inline;">
            <button type="submit" class="delete-btn">Xóa</button>
        </form>
    </div>
</li>