{{!-- Trang form chỉnh sửa nhiệm vụ --}}
<h2>Sửa nhiệm vụ: {{task.name}}</h2>
<form action="/tasks/edit/{{task.id}}" method="POST">
    <div>
        <label for="name">Tên nhiệm vụ:</label>
        <input type="text" id="name" name="name" value="{{task.name}}"required>
    </div>
    <div>
        <label for="description">Mô tả:</label>
        <textarea id="description" name="description" rows="4">{{task.description}}</textarea>
    </div>
    <div>
        <label for="completed">
        <input type="checkbox" id="completed" name="completed" {{#if task.completed}}checked{{/if}}> Đã hoàn thành
        </label>
    </div>
    <div>
        <button type="submit">Cập nhật nhiệm vụ</button>
    </div>
</form>