<%- include("../layouts/header.ejs") %>

<div class="container mt-4" style="max-width: 600px">
  <h3 class="mb-4">Edit Question</h3>

  <form method="post" action="/questions/<%= question._id %>/edit">
    <!-- Question Text -->
    <div class="mb-3">
      <label class="form-label fw-bold">Question Text</label>
      <input
        type="text"
        name="text"
        class="form-control"
        value="<%= question.text %>"
        required
      />
    </div>

    <!-- Correct Answer Index -->
    <div class="mb-4">
      <label class="form-label fw-bold"> Correct Answer Index (0-based) </label>
      <input
        type="number"
        name="correctAnswerIndex"
        class="form-control"
        value="<%= question.correctAnswerIndex %>"
        required
      />
      <div class="form-text">Example: 0 = Option 1, 1 = Option 2</div>
    </div>

    <!-- Buttons -->
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary">Save Changes</button>

      <a href="/questions" class="btn btn-secondary"> Cancel </a>
    </div>
  </form>
</div>

<%- include("../layouts/footer.ejs") %>
